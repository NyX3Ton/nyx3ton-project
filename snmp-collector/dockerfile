# Použijeme Python image, ktorý už má pip
FROM python:3.12-slim

# Inštalácia systémových závislostí
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates gnupg \
    unixodbc unixodbc-dev \
 && rm -rf /var/lib/apt/lists/*

# MS ODBC Driver 18 for SQL Server
RUN curl -fsSL https://packages.microsoft.com/keys/microsoft.asc \
    | gpg --dearmor -o /usr/share/keyrings/ms.gpg && \
    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/ms.gpg] https://packages.microsoft.com/ubuntu/22.04/prod jammy main" \
    > /etc/apt/sources.list.d/microsoft-prod.list && \
    apt-get update && ACCEPT_EULA=Y apt-get install -y --no-install-recommends msodbcsql18 && \
    rm -rf /var/lib/apt/lists/*

# Python knižnice (pysnmp + crypto + pandas + SQL)
RUN pip install --no-cache-dir \
    "pysnmp>=7.1" "pyasn1>=0.6" "pycryptodomex>=3.17" \
    pandas sqlalchemy pyodbc nest_asyncio

ENV PYSNMP_CRYPTO_LIB=pycryptodomex

# Pracovný priečinok a skript
WORKDIR /app
COPY app.py /app/app.py

CMD ["python", "app.py"]