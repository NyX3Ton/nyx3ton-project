FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    ACCEPT_EULA=Y

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev build-essential \
    curl ca-certificates gnupg \
    unixodbc unixodbc-dev \
  && rm -rf /var/lib/apt/lists/*

# Microsoft ODBC 18
RUN curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/ms.gpg && \
    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/ms.gpg] https://packages.microsoft.com/ubuntu/22.04/prod jammy main" \
      > /etc/apt/sources.list.d/microsoft-prod.list && \
    apt-get update && apt-get install -y --no-install-recommends msodbcsql18 && \
    rm -rf /var/lib/apt/lists/*

# Python deps — NOTE: pycryptodomex (not pycryptodome)
# Python deps — include the crypto plugin
RUN pip3 install --no-cache-dir \
    pysnmp>=7 pyasn1 pycryptodomex pysnmpcrypto \
    pandas sqlalchemy pyodbc nest_asyncio

WORKDIR /app
COPY app.py /app/app.py
CMD ["python3", "app.py"]
